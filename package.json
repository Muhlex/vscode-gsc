{
	"name": "vscode-gsc",
	"displayName": "CoD: Game Script Code",
	"description": "Language support for different GSC versions",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.69.0"
	},
	"categories": [
		"Programming Languages"
	],
	"scripts": {
		"vscode:prepublish": "npm run compile && npm run build",
		"build": "ts-node src/build/index.ts",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"lint": "eslint src --ext ts"
	},
	"main": "./out/extension",
	"activationEvents": [
		"onLanguage:gsc-iw3",
		"onLanguage:gsc-iw4"
	],
	"contributes": {
		"languages": [
			{
				"id": "gsc-iw3",
				"aliases": [
					"Game Script Code (IW3)",
					"GSC (IW3)"
				],
				"extensions": [
					".gsc",
					".csc"
				],
				"configuration": "./static/language-configuration.json",
				"icon": {
					"light": "./static/icons/gsc-iw3.svg",
					"dark": "./static/icons/gsc-iw3.svg"
				}
			},
			{
				"id": "gsc-iw4",
				"aliases": [
					"Game Script Code (IW4)",
					"GSC (IW4)"
				],
				"extensions": [
					".gsc",
					".csc"
				],
				"configuration": "./static/language-configuration.json",
				"icon": {
					"light": "./static/icons/gsc-iw4.svg",
					"dark": "./static/icons/gsc-iw4.svg"
				}
			}
		],
		"grammars": [
			{
				"language": "gsc-iw3",
				"scopeName": "source.gsc",
				"path": "./out/grammars/gsc-iw3.tmLanguage.json"
			},
			{
				"language": "gsc-iw4",
				"scopeName": "source.gsc",
				"path": "./out/grammars/gsc-iw4.tmLanguage.json"
			}
		]
	},
	"devDependencies": {
		"@types/node": "^18.0.6",
		"@types/vscode": "^1.69.0",
		"@typescript-eslint/eslint-plugin": "^5.30.7",
		"@typescript-eslint/parser": "^5.30.7",
		"eslint": "^8.20.0",
		"ts-node": "^10.8.2",
		"typescript": "^4.7.4"
	}
}
